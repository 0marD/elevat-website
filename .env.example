# .env.example — copiar como .env.local y completar con valores reales

# Base de datos (Supabase PostgreSQL)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Autenticación admin
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Email (Resend)
RESEND_API_KEY=

# WhatsApp número de destino
NEXT_PUBLIC_WHATSAPP_NUMBER=523337084290

# Almacenamiento de imágenes (Cloudinary o Supabase Storage)
CLOUDINARY_URL=

# Push Notifications (Web Push / VAPID)
# Generar con: yarn generate-vapid
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@eleva.mx
